# === DeskSkill TeamBoard 服务端环境变量 ===
# 复制为 .env 后填入真实值：cp .env.example .env

# 服务端口
PORT=3001

# DeskHub 技能市场 API
DESKHUB_BASE=https://skills.deskclaw.me

# Umami 网站统计
UMAMI_BASE=https://umami.deskclaw.me
UMAMI_WEBSITE_ID=
UMAMI_USERNAME=
UMAMI_PASSWORD=

# DeskClaw MCP 代理端点
MCP_ENDPOINT=https://mcp.deskclaw.me/deskclaw/mcp

# MCP OAuth 签发者地址（生产环境必须设为公网 URL）
# MCP_ISSUER_URL=https://your-domain.com

# JWT 密钥（生产环境必填，至少 32 位随机字符串）
# 生成方式：openssl rand -hex 32
# JWT_SECRET=

# CORS 允许的来源（逗号分隔，不设则全放行）
# CORS_ORIGIN=https://your-domain.com

# 飞书 LLM 机器人
BOT_ENABLED=true
BOT_POLL_INTERVAL=30000
BOT_DAILY_SUMMARY_HOUR=11
BOT_BATCH_THRESHOLD=3
FEISHU_APP_ID=
FEISHU_APP_SECRET=
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-M2.7-highspeed

# 静态 MCP API Token（可选，绕过 OAuth 的服务间调用）
# MCP_API_TOKEN=

# === InkLoop Vault Release（交付路线 Y·设备→panel 存→Obsidian 下载器拉）===
# InkLoop 调 /api/feishu/* 与 /api/inkloop/vault/* 的共享密钥（与 InkLoop 侧 INKLOOP_SHARED_SECRET 一致）
INKLOOP_SHARED_SECRET=
# vault release blob 落盘目录（非公开·默认 server/vault-releases）
VAULT_RELEASE_DIR=
# release 上传 body 上限（默认 50mb）
VAULT_RELEASE_BODY_LIMIT=50mb
# release 文件数上限（默认 2000）
VAULT_RELEASE_MAX_FILES=2000
# manifest path 最大 UTF-8 字节（默认 1024）
VAULT_RELEASE_MAX_PATH_BYTES=1024
